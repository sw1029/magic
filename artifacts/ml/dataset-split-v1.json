{
  "artifactType": "dataset_split_manifest",
  "version": "v1",
  "schemaVersion": "tiny-ml-dataset-split-v1",
  "datasetSchemaVersion": "tutorial-hybrid-v1",
  "roles": {
    "public_auxiliary": {
      "role": "public_auxiliary",
      "description": "encoder pretrain, normalization prior, denoising prior",
      "priorities": [
        "public_auxiliary"
      ],
      "splits": [
        "pretrain"
      ],
      "usage": {
        "allowed": [
          "normalization_regression",
          "stroke_encoder_pretrain",
          "denoising_prior",
          "sequence_representation"
        ],
        "forbidden": [
          "direct_family_classifier_training",
          "direct_operator_classifier_training",
          "semantic_label_override"
        ]
      },
      "directSemanticSupervision": false
    },
    "synthetic_primary": {
      "role": "synthetic_primary",
      "description": "domain supervision mainline for base family/operator rerank and confidence calibration",
      "priorities": [
        "synthetic_bootstrap",
        "synthetic_tutorial_like",
        "synthetic_hard_negative",
        "synthetic_placement_shift"
      ],
      "splits": [
        "train",
        "eval",
        "hard_negative_eval"
      ],
      "usage": {
        "allowed": [
          "prototype_bootstrap",
          "operator_bootstrap",
          "hard_negative_bootstrap",
          "normalization_regression",
          "rerank_supervision",
          "confidence_calibration",
          "hard_negative_eval"
        ],
        "forbidden": []
      },
      "directSemanticSupervision": true
    },
    "tutorial_primary": {
      "role": "tutorial_primary",
      "description": "user adaptation, prototype bank, personalized rerank calibration, acceptance evaluation",
      "priorities": [
        "tutorial_primary"
      ],
      "splits": [
        "adaptation",
        "acceptance_eval"
      ],
      "usage": {
        "allowed": [
          "user_adaptation",
          "prototype_bank",
          "rerank_calibration",
          "acceptance_eval"
        ],
        "forbidden": []
      },
      "directSemanticSupervision": true
    }
  },
  "splitPolicy": {
    "public_auxiliary": {
      "requiredSplits": [
        "pretrain"
      ],
      "directSemanticSupervision": false,
      "notes": [
        "public auxiliary stays in auxiliary-only pretrain lanes",
        "direct family/operator supervision remains forbidden"
      ]
    },
    "synthetic_primary": {
      "requiredSplits": [
        "train",
        "eval",
        "hard_negative_eval"
      ],
      "defaultPresets": [
        {
          "preset": "bootstrap",
          "defaultSplit": "train",
          "priority": "synthetic_bootstrap"
        },
        {
          "preset": "tutorial-like",
          "defaultSplit": "train",
          "priority": "synthetic_tutorial_like"
        },
        {
          "preset": "hard-negative",
          "defaultSplit": "hard_negative_eval",
          "priority": "synthetic_hard_negative"
        },
        {
          "preset": "placement-shift",
          "defaultSplit": "train",
          "priority": "synthetic_placement_shift"
        }
      ],
      "directSemanticSupervision": true
    },
    "tutorial_primary": {
      "requiredSplits": [
        "adaptation",
        "acceptance_eval"
      ],
      "activation": "next-phase vector tutorial capture",
      "directSemanticSupervision": true
    }
  },
